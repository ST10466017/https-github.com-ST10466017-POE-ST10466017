<Window x:Class="ZoroChatbot.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zoro - Cybersecurity Chatbot" 
        Height="700" Width="900"
        Background="#1A1A2E"
        WindowStartupLocation="CenterScreen">

	<Window.Resources>
		<Style x:Key="ChatBubbleStyle" TargetType="Border">
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="Padding" Value="12,8"/>
			<Setter Property="Margin" Value="5"/>
		</Style>
	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Header with ASCII Art -->
		<Border Grid.Row="0" Background="#16213E" Padding="10">
			<StackPanel>
				<TextBlock Text="????????????????????????????????????????????????????????????"
                          FontFamily="Consolas" Foreground="#00D2FF" FontSize="12"/>
				<TextBlock Text="?  ???????? ??????? ???????  ??????? ??????? ???  ???  ?"
                          FontFamily="Consolas" Foreground="#00D2FF" FontSize="12"/>
				<TextBlock Text="?  ?????????????????????????????????????????????  ???  ?"
                          FontFamily="Consolas" Foreground="#00D2FF" FontSize="12"/>
				<TextBlock Text="?    ????? ???   ??????????????   ???????????????????  ?"
                          FontFamily="Consolas" Foreground="#00D2FF" FontSize="12"/>
				<TextBlock Text="?   ?????  ???   ??????????????   ???????????????????  ?"
                          FontFamily="Consolas" Foreground="#00D2FF" FontSize="12"/>
				<TextBlock Text="?  ????????????????????  ???????????????  ??????  ???  ?"
                          FontFamily="Consolas" Foreground="#00D2FF" FontSize="12"/>
				<TextBlock Text="?  ???????? ??????? ???  ??? ??????? ???  ??????  ???  ?"
                          FontFamily="Consolas" Foreground="#00D2FF" FontSize="12"/>
				<TextBlock Text="?          ?? CYBERSECURITY AWARENESS BOT ??           ?"
                          FontFamily="Consolas" Foreground="#FFD700" FontSize="12" FontWeight="Bold"/>
				<TextBlock Text="????????????????????????????????????????????????????????????"
                          FontFamily="Consolas" Foreground="#00D2FF" FontSize="12"/>
			</StackPanel>
		</Border>

		<!-- Chat Messages Area -->
		<ScrollViewer Grid.Row="1" 
                     x:Name="MessageScrollViewer"
                     Background="#1A1A2E"
                     VerticalScrollBarVisibility="Auto">
			<StackPanel x:Name="MessagePanel" 
                       Margin="15"
                       Orientation="Vertical">
			</StackPanel>
		</ScrollViewer>

		<!-- Input Area -->
		<Border Grid.Row="2" 
                Background="#16213E" 
                Padding="10" 
                BorderBrush="#00D2FF" 
                BorderThickness="0,1,0,0">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBox x:Name="InputTextBox" 
                        Grid.Column="0"
                        Background="#1A1A2E"
                        Foreground="White"
                        BorderBrush="#00D2FF"
                        BorderThickness="2"
                        Padding="10,8"
                        FontSize="14"
                        KeyDown="InputTextBox_KeyDown">
					<TextBox.Resources>
						<Style TargetType="{x:Type Border}">
							<Setter Property="CornerRadius" Value="8"/>
						</Style>
					</TextBox.Resources>
				</TextBox>

				<Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="?? Send"
                        Background="#00D2FF"
                        Foreground="#1A1A2E"
                        FontWeight="Bold"
                        Padding="15,8"
                        Margin="8,0,0,0"
                        Click="SendButton_Click">
					<Button.Resources>
						<Style TargetType="{x:Type Border}">
							<Setter Property="CornerRadius" Value="8"/>
						</Style>
					</Button.Resources>
				</Button>

				<Button x:Name="ClearButton"
                        Grid.Column="2"
                        Content="??? Clear"
                        Background="#FF6B6B"
                        Foreground="White"
                        FontWeight="Bold"
                        Padding="15,8"
                        Margin="5,0,0,0"
                        Click="ClearButton_Click">
					<Button.Resources>
						<Style TargetType="{x:Type Border}">
							<Setter Property="CornerRadius" Value="8"/>
						</Style>
					</Button.Resources>
				</Button>
			</Grid>
		</Border>
	</Grid>
</Window>