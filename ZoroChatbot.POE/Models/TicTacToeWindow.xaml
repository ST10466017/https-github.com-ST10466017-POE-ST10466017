<Window x:Class="ZoroChatbot.POE.TicTacToeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎮 Tic-Tac-Toe - Mini Game" 
        Height="600" Width="550"
        Background="#1A1A2E"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="🎮 Tic-Tac-Toe"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#FFD700"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Status -->
        <Border Grid.Row="1"
                Background="#16213E"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,15">
            <TextBlock x:Name="StatusText"
                       Text="Your turn (X)"
                       FontSize="16"
                       Foreground="#00D2FF"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Game Board -->
        <Grid Grid.Row="2"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Grid.Resources>
                <Style TargetType="Button">
                    <Setter Property="Width" Value="80"/>
                    <Setter Property="Height" Value="80"/>
                    <Setter Property="FontSize" Value="36"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Background" Value="#16213E"/>
                    <Setter Property="Foreground" Value="#00D2FF"/>
                    <Setter Property="BorderBrush" Value="#00D2FF"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Margin" Value="2"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1A3A5E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Grid.Resources>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button x:Name="Btn00" Grid.Row="0" Grid.Column="0" Click="Cell_Click" Tag="0,0"/>
            <Button x:Name="Btn01" Grid.Row="0" Grid.Column="1" Click="Cell_Click" Tag="0,1"/>
            <Button x:Name="Btn02" Grid.Row="0" Grid.Column="2" Click="Cell_Click" Tag="0,2"/>
            <Button x:Name="Btn10" Grid.Row="1" Grid.Column="0" Click="Cell_Click" Tag="1,0"/>
            <Button x:Name="Btn11" Grid.Row="1" Grid.Column="1" Click="Cell_Click" Tag="1,1"/>
            <Button x:Name="Btn12" Grid.Row="1" Grid.Column="2" Click="Cell_Click" Tag="1,2"/>
            <Button x:Name="Btn20" Grid.Row="2" Grid.Column="0" Click="Cell_Click" Tag="2,0"/>
            <Button x:Name="Btn21" Grid.Row="2" Grid.Column="1" Click="Cell_Click" Tag="2,1"/>
            <Button x:Name="Btn22" Grid.Row="2" Grid.Column="2" Click="Cell_Click" Tag="2,2"/>
        </Grid>

        <!-- Controls -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button x:Name="ResetButton"
                    Content="🔄 New Game"
                    Background="#00D2FF"
                    Foreground="#1A1A2E"
                    FontWeight="Bold"
                    FontSize="16"
                    Padding="20,10"
                    Margin="0,0,10,0"
                    Click="ResetButton_Click">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="CloseButton"
                    Content="❌ Close Game"
                    Background="#FF6B6B"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="16"
                    Padding="20,10"
                    Click="CloseButton_Click">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- Instructions -->
        <Border Grid.Row="4"
                Background="#16213E"
                CornerRadius="8"
                Padding="10"
                Margin="0,15,0,0">
            <TextBlock Text="💡 Click a cell to place your X. The computer plays as O."
                       FontSize="12"
                       Foreground="#8899AA"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>